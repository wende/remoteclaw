{
  "id": "remoteclaw",
  "name": "RemoteClaw",
  "description": "MCP server exposing OpenClaw tools to Claude Desktop/Claude.ai",
  "configSchema": {
    "type": "object",
    "properties": {
      "gatewayUrl": {
        "type": "string",
        "default": "http://localhost:18789",
        "description": "URL of the OpenClaw gateway"
      },
      "gatewayToken": {
        "type": "string",
        "description": "Bearer token for gateway authentication"
      },
      "sessionKey": {
        "type": "string",
        "default": "main",
        "description": "Session key for tool invocations"
      },
      "port": {
        "type": "number",
        "default": 3100,
        "description": "Port for the MCP HTTP server"
      },
      "tlsCert": {
        "type": "string",
        "description": "Path to TLS certificate PEM file (auto-detects certs/ dir if omitted)"
      },
      "tlsKey": {
        "type": "string",
        "description": "Path to TLS private key PEM file (auto-detects certs/ dir if omitted)"
      }
    },
    "additionalProperties": false
  }
}
